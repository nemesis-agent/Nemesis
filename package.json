{
  "name": "nemesis",
  "version": "0.1.0",
  "private": true,
  "description": "NEMESIS - approval-first agents on Base and Solana.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces",
    "build": "npm run build:web && npm run build:bot",
    "build:db": "npm run build --workspace=@nemesis/db",
    "seed:db": "npm run seed --workspace=@nemesis/db",
    "build:web": "npm run prebuild:web && npm run build --workspace=@nemesis/web",
    "prebuild:web": "npm run build:db",
    "build:bot": "npm run prebuild:bot && npm run build --workspace=@nemesis/telegram-bot",
    "prebuild:bot": "npm run build:db",
    "start": "pm2-runtime ecosystem.config.js",
    "smoke:prod": "node tools/smoke-production.mjs",
    "audit:p1": "node tools/audit-p1.mjs",
    "audit:p2": "node tools/audit-p2.mjs",
    "audit:privacy": "node tools/audit-privacy.mjs",
    "audit:agent-quality": "node tools/audit-agent-quality.mjs",
    "audit:real-execution": "node tools/audit-real-execution.mjs",
    "audit:growth": "node tools/audit-growth.mjs",
    "audit:docs": "node tools/audit-docs.mjs",
    "audit:observability": "node tools/audit-observability.mjs",
    "audit:explainability": "node tools/audit-explainability.mjs",
    "audit:template-detail": "node tools/audit-template-detail.mjs",
    "audit:copy-metadata": "node tools/audit-copy-metadata.mjs",
    "test:p0": "node --no-warnings --experimental-strip-types tests/execution-policy.test.ts",
    "test:e2e": "playwright test"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^10.0.3",
    "pm2": "^7.0.1"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
