# NEMESIS web environment
# Required in production. Keep secrets in your deploy provider, never commit .env files.

# Supabase Postgres connection string used by @nemesis/db.
# For a long-running Railway container, Supabase direct or session-pooler mode is preferred.
DATABASE_URL=

# Strong unique secret for iron-session cookies. Minimum 32 characters.
SESSION_SECRET=

# Master Agent LLM provider key. /api/intent returns 503 until this is set.
OPENROUTER_API_KEY=

# Low-cost default Master Agent model on OpenRouter.
OPENROUTER_MODEL=xiaomi/mimo-v2.5

# WalletConnect project ID from https://cloud.walletconnect.com.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Public canonical URL, e.g. https://nemesis.example.com.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
