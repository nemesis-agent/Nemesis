# NEMESIS Telegram bot environment
# Required in production. Keep secrets in your deploy provider, never commit .env files.

# Supabase Postgres connection string used by @nemesis/db.
DATABASE_URL=

# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Optional launch allow-list for private beta. Leave empty only when the bot should accept any linked user.
NEMESIS_ALLOWED_USER_IDS=

# Optional logging level: trace, debug, info, warn, error, fatal.
LOG_LEVEL=info
